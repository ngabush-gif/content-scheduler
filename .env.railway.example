# Railway Environment Variables - ContentHub Facebook Scheduler
# Copy these to your Railway project's Variables tab

# Database Connection
DATABASE_URL=mysql://user:password@host:3306/database_name

# JWT & Security
JWT_SECRET=your_jwt_secret_key_here

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=https://your-railway-domain.railway.app/api/oauth/callback

# App Configuration
NODE_ENV=production
PORT=3000
VITE_APP_ID=your_facebook_app_id
VITE_APP_TITLE=ContentHub
VITE_APP_LOGO=https://your-logo-url.com/logo.png

# Optional: Manus Integration (if still using Manus services)
OWNER_NAME=Your Name
OWNER_OPEN_ID=your_open_id
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_api_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your_frontend_api_key

# Scheduler Configuration
CRON_SECRET_TOKEN=tw_scheduler_9Xk28_secure_2026
